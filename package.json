{
  "name": "swell-child-theme",
  "private": true,
  "scripts": {
    "build": "npm run build:css && npm run build:dp",
    "dev": "npm run watch:all:poll",
    "doctor": "node ./scripts/doctor.mjs",
    "build:css": "sass --no-source-map scss/style.scss:style.css",
    "build:patterns": "cp output/block-code/*.html ../../plugins/swell-dp/patterns/ && cp output/manifest.json ../../plugins/swell-dp/patterns/",
    "build:dp": "sass --no-source-map scss/dp-style.scss:dp-style.css && npm run build:patterns && cp dp-style.css ../../plugins/swell-dp/assets/css/dp-style.css",
    "watch:css": "sass --watch --no-source-map scss/style.scss:style.css scss/dp-style.scss:dp-style.css",
    "watch:css:poll": "sass --watch --poll --no-source-map scss/style.scss:style.css scss/dp-style.scss:dp-style.css",
    "watch:all:poll": "node scripts/watch-dp.mjs"
  },
  "devDependencies": {
    "sass": "^1.77.0"
  }
}